{
  "name": "crate-digger-web",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner --host 127.0.0.1",
    "build": "tsc --noEmit && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner --host 127.0.0.1",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:e2e": "playwright test",
    "api:generate": "openapi-typescript openapi.json -o src/lib/openapi.d.ts",
    "desktop:dev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/desktop.ps1 dev",
    "desktop:build": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/desktop.ps1 build",
    "desktop:check": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../scripts/desktop.ps1 check"
  },
  "dependencies": {
    "@tanstack/react-query": "latest",
    "@tauri-apps/api": "latest",
    "@tauri-apps/plugin-dialog": "latest",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "clsx": "latest",
    "lucide-react": "latest",
    "radix-ui": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "wavesurfer.js": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/vite": "latest",
    "@tauri-apps/cli": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "openapi-typescript": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
